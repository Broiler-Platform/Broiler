<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>Broiler.Documents.Markdown</RootNamespace>
    <AssemblyName>Broiler.Documents.Markdown</AssemblyName>
    <PackageId>Broiler.Documents.Markdown</PackageId>
    <Description>Markdown document codec for Broiler.Documents over a safe CommonMark-oriented subset.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Broiler.Documents\Broiler.Documents.csproj" />
    <ProjectReference Include="..\Broiler.Documents.Model\Broiler.Documents.Model.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Broiler.Documents.Markdown.Tests" />
  </ItemGroup>

</Project>
