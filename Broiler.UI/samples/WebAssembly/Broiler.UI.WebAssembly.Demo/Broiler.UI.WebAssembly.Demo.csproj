<Project Sdk="Microsoft.NET.Sdk.WebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <IsPackable>false</IsPackable>
    <RootNamespace>Broiler.UI.WebAssembly.Demo</RootNamespace>
    <AssemblyName>Broiler.UI.WebAssembly.Demo</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\Broiler.Graphics\Broiler.Graphics.WebAssembly\Broiler.Graphics.WebAssembly.csproj" />
    <ProjectReference Include="..\..\..\..\Broiler.Graphics\Broiler.Graphics\Broiler.Graphics.csproj" />
    <ProjectReference Include="..\..\..\..\Broiler.Input\Broiler.Input\Broiler.Input.csproj" />
    <ProjectReference Include="..\..\..\..\Broiler.Input\Broiler.Input.Keyboard\Broiler.Input.Keyboard.csproj" />
    <ProjectReference Include="..\..\..\..\Broiler.Input\Broiler.Input.Mouse\Broiler.Input.Mouse.csproj" />
    <ProjectReference Include="..\..\..\..\Broiler.Input\Broiler.Input.Text\Broiler.Input.Text.csproj" />
    <ProjectReference Include="..\..\..\src\Foundation\Broiler.UI.Standard\Broiler.UI.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Shell\Broiler.UI.Window.Standard\Broiler.UI.Window.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Layout\Broiler.UI.Panel.Standard\Broiler.UI.Panel.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Content\Broiler.UI.Label.Standard\Broiler.UI.Label.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Commands\Broiler.UI.Button.Standard\Broiler.UI.Button.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Text\Broiler.UI.Edit.Standard\Broiler.UI.Edit.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\ValueAndSelection\Broiler.UI.CheckBox.Standard\Broiler.UI.CheckBox.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\ValueAndSelection\Broiler.UI.RadioButton.Standard\Broiler.UI.RadioButton.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Commands\Broiler.UI.ToggleButton.Standard\Broiler.UI.ToggleButton.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\ValueAndSelection\Broiler.UI.Slider.Standard\Broiler.UI.Slider.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Content\Broiler.UI.ProgressBar.Standard\Broiler.UI.ProgressBar.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Content\Broiler.UI.ImageView.Standard\Broiler.UI.ImageView.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Layout\Broiler.UI.ScrollView.Standard\Broiler.UI.ScrollView.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\ValueAndSelection\Broiler.UI.ListView.Standard\Broiler.UI.ListView.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\ValueAndSelection\Broiler.UI.ComboBox.Standard\Broiler.UI.ComboBox.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Layout\Broiler.UI.TabView.Standard\Broiler.UI.TabView.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Commands\Broiler.UI.Menu.Standard\Broiler.UI.Menu.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Shell\Broiler.UI.Tooltip.Standard\Broiler.UI.Tooltip.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Shell\Broiler.UI.Dialog.Standard\Broiler.UI.Dialog.Standard.csproj" />
    <ProjectReference Include="..\..\..\src\Abstractions\Commands\Broiler.UI.Toolbar\Broiler.UI.Toolbar.csproj" />
    <ProjectReference Include="..\..\..\src\Implementations\Standard\Commands\Broiler.UI.Toolbar.Standard\Broiler.UI.Toolbar.Standard.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Only fingerprint the app entry module. The Phase 5 direct-Canvas backend module is
         loaded from managed code (JSHost.ImportAsync) by a stable literal URL, so it must not
         be renamed by fingerprinting. -->
    <StaticWebAssetFingerprintPattern Include="MainJs" Pattern="main.js" Expression="#[.{fingerprint}]!" />
  </ItemGroup>

  <!-- Vendor the canonical Canvas 2D replay module from the backend into this sample's wwwroot
       so it publishes as a stable static asset. The backend project owns the source of truth. -->
  <Target Name="SyncCanvasReplayModule" BeforeTargets="BeforeBuild;BeforePublish">
    <Copy SourceFiles="..\..\..\..\Broiler.Graphics\Broiler.Graphics.WebAssembly\wwwroot\broiler.graphics.webassembly.js" DestinationFolder="$(MSBuildProjectDirectory)\wwwroot" SkipUnchangedFiles="true" />
  </Target>

</Project>
