<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>Broiler.UI.RichEdit.Rtf</RootNamespace>
    <AssemblyName>Broiler.UI.RichEdit.Rtf</AssemblyName>
    <PackageId>Broiler.UI.RichEdit.Rtf</PackageId>
    <Description>Optional RTF rich-clipboard adapter for Broiler.UI RichEdit (ADR 0016/0018): copy/paste formatted content via CF_RTF without pulling a codec into the core control.</Description>
  </PropertyGroup>

  <!--
    The optional rich-clipboard adapter (ADR 0016/0018): it bridges the RichEdit
    control to the RTF codec so the core control stays codec-free. References the
    control, the document model, and the RTF codec â€” no OS/clipboard dependency
    (the host supplies an IUiRichClipboardHost).
  -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\Abstractions\Text\Broiler.UI.RichEdit\Broiler.UI.RichEdit.csproj" />
    <ProjectReference Include="..\..\..\..\..\Broiler.Documents\Broiler.Documents\Broiler.Documents.csproj" />
    <ProjectReference Include="..\..\..\..\..\Broiler.Documents\Broiler.Documents.Rtf\Broiler.Documents.Rtf.csproj" />
    <ProjectReference Include="..\..\..\..\..\Broiler.Documents\Broiler.Documents.Model\Broiler.Documents.Model.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Broiler.UI.RichEdit.Rtf.Tests" />
  </ItemGroup>

</Project>
