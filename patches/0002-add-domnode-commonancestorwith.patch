From 9f935b7803aa88b6fc09521ab2e7b2a4b1baf964 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Tue, 14 Jul 2026 07:11:15 +0000
Subject: [PATCH] Add DomNode.CommonAncestorWith (null-tolerant nearest common
 ancestor)

Neutral tree query promoted from the HtmlBridge (Broiler HtmlBridge
complexity-reduction roadmap Phase 4 items 4/5). Returns the deepest node that
is an inclusive ancestor of both this node and the argument, or null when they
are in different trees (or the argument is null). Unlike
DomRange.CommonAncestorContainer (two boundary points in one tree, throws
otherwise), this is a null-tolerant node-level query for arbitrary node pairs.
The bridge's FindCommonAncestor helper delegates to this.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 Broiler.Dom/DomNode.cs | 21 +++++++++++++++++++++
 1 file changed, 21 insertions(+)

diff --git a/Broiler.Dom/DomNode.cs b/Broiler.Dom/DomNode.cs
index ee9607d..bf556fd 100644
--- a/Broiler.Dom/DomNode.cs
+++ b/Broiler.Dom/DomNode.cs
@@ -225,6 +225,27 @@ public abstract class DomNode
         return false;
     }
 
+    /// <summary>
+    /// The nearest common inclusive ancestor of this node and <paramref name="other"/> — the deepest
+    /// node that is an inclusive ancestor of both — or <c>null</c> when they belong to different trees
+    /// (or <paramref name="other"/> is <c>null</c>). "Inclusive" means a node is its own ancestor, so
+    /// if one node is an ancestor of the other, that node is returned. Unlike
+    /// <see cref="DomRange.CommonAncestorContainer"/> (which requires two boundary points in one tree
+    /// and throws otherwise), this is a null-tolerant node-level query for arbitrary node pairs.
+    /// </summary>
+    public DomNode? CommonAncestorWith(DomNode? other)
+    {
+        if (other is null)
+            return null;
+        var ancestors = InclusiveAncestors().ToHashSet();
+        foreach (var ancestor in other.InclusiveAncestors())
+        {
+            if (ancestors.Contains(ancestor))
+                return ancestor;
+        }
+        return null;
+    }
+
     public void Normalize()
     {
         for (var index = 0; index < _children.Count;)
