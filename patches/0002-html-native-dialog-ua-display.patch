From c06c0b2d67830c389364696f132a6187cbf74654 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Thu, 16 Jul 2026 13:14:23 +0000
Subject: [PATCH] Add native UA <dialog> display rules
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Replaces the DomBridge InsertDialogBackdrops display:block pre-bake: an open dialog is a
block box, a closed dialog is display:none (spec dialog:not([open]){display:none}). Also
fixes bare non-modal <dialog open>, which the bridge only handled for modal dialogs.
Requires the Broiler.CSS :not([attr]) selector-matcher fix (patch 0001) — without it,
:not([open]) is inverted and hides open dialogs. Box chrome (border/padding/background)
and modal centering are deferred to later slices (chrome needs the author-vs-UA origin
precedence fix).

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 Source/Broiler.HTML.Core/CssDefaults.cs | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/Source/Broiler.HTML.Core/CssDefaults.cs b/Source/Broiler.HTML.Core/CssDefaults.cs
index 0864d3e..384c6e1 100644
--- a/Source/Broiler.HTML.Core/CssDefaults.cs
+++ b/Source/Broiler.HTML.Core/CssDefaults.cs
@@ -132,8 +132,13 @@ internal static class CssDefaults
         /* HTML5 text-level elements – inline by default */
         mark            { background-color: yellow; color: black }
 
+        /* HTML <dialog> — native UA display (open dialogs are block boxes; closed are
+           display:none). Requires the :not([open]) selector-matcher fix. */
+        dialog          { display: block }
+        dialog:not([open]) { display: none }
+
         /* Hidden elements (HTML5) */
-        template, dialog,
+        template,
         [hidden]        { display: none }
         style, title,
         script, link,
