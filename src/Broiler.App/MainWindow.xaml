<Window x:Class="Broiler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:htmlRenderer="clr-namespace:Broiler.HTML.WPF;assembly=Broiler.HTML.WPF"
        xmlns:devConsole="clr-namespace:Broiler.App.DevConsole"
        Title="Broiler" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="ConsoleRow" Height="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button x:Name="BackButton" Content="◀" Width="32" Height="28" Margin="2"
                            Click="BackButton_Click" ToolTip="Back"/>
                    <Button x:Name="ForwardButton" Content="▶" Width="32" Height="28" Margin="2"
                            Click="ForwardButton_Click" ToolTip="Forward"/>
                    <Button x:Name="RefreshButton" Content="⟳" Width="32" Height="28" Margin="2"
                            Click="RefreshButton_Click" ToolTip="Refresh"/>
                </StackPanel>
                <Button x:Name="FavoriteButton" DockPanel.Dock="Right" Content="☆" Width="32" Height="28" Margin="4,0,0,0"
                        Click="FavoriteButton_Click" ToolTip="Add to Favorites"/>
                <Button x:Name="GoButton" DockPanel.Dock="Right" Content="Go" Width="48" Height="28" Margin="4,0,0,0"
                        Click="GoButton_Click"/>
                <TextBox x:Name="UrlTextBox" Height="28" VerticalContentAlignment="Center" Padding="4,0"
                         KeyDown="UrlTextBox_KeyDown"/>
            </DockPanel>
        </Border>

        <!-- Favorites Bar -->
        <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="2,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="★ Favorites" VerticalAlignment="Center"
                           Margin="4,0,6,0" FontSize="11" Foreground="#555555"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="FavoritesPanel" Orientation="Horizontal"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- HTML Rendering Area -->
        <htmlRenderer:HtmlPanel x:Name="HtmlPanel" Grid.Row="2"
                                AvoidImagesLateLoading="True"
                                AvoidAsyncImagesLoading="True"
                                LinkClicked="HtmlPanel_LinkClicked"/>

        <!-- Console Splitter (only visible when console is open) -->
        <GridSplitter x:Name="ConsoleSplitter" Grid.Row="3" Height="4" Background="#3E3E3E"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Visibility="Collapsed"/>

        <!-- Developer Console Panel -->
        <devConsole:DevConsolePanel x:Name="DevConsole" Grid.Row="4"
                                    Visibility="Collapsed"/>

        <!-- Status Bar -->
        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
