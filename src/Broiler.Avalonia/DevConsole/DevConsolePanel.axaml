<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Broiler.Avalonia.DevConsole.DevConsolePanel">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Tab bar -->
            <RowDefinition Height="Auto"/>
            <!-- Tab content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab header bar -->
        <Border Grid.Row="0" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Background="#2D2D2D">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="LogTab" Content="Log Viewer" GroupName="ConsoleTabs"
                             IsChecked="True"
                             Foreground="#999" FontSize="12" Padding="12,6" Margin="0"
                             Click="Tab_Checked" Tag="Log"/>
                <RadioButton x:Name="DomTab" Content="DOM Inspector" GroupName="ConsoleTabs"
                             Foreground="#999" FontSize="12" Padding="12,6" Margin="0"
                             Click="Tab_Checked" Tag="Dom"/>
                <RadioButton x:Name="JsTab" Content="JS Console" GroupName="ConsoleTabs"
                             Foreground="#999" FontSize="12" Padding="12,6" Margin="0"
                             Click="Tab_Checked" Tag="Js"/>
                <!-- Error indicator badge -->
                <Border x:Name="ErrorBadge" CornerRadius="8" Padding="6,2"
                        Margin="8,4" VerticalAlignment="Center" IsVisible="False"
                        Background="#E74C3C">
                    <TextBlock x:Name="ErrorCount" Text="0 errors" Foreground="White"
                               FontSize="11"/>
                </Border>
                <Button Content="✕" Width="24" Height="24" Margin="8,2"
                        Foreground="#999" BorderThickness="0" Click="CloseButton_Click"
                        ToolTip.Tip="Close (F12)" HorizontalAlignment="Right"
                        VerticalContentAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Log Viewer Tab -->
        <Grid x:Name="LogPanel" Grid.Row="1" IsVisible="True" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filters -->
            <Border Grid.Row="0" Padding="4" Background="#2D2D2D">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Level:" Foreground="#CCC" VerticalAlignment="Center" Margin="4,0"/>
                    <ComboBox x:Name="LogLevelFilter" Width="90" Margin="2,0"
                              SelectionChanged="LogFilter_Changed">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Debug"/>
                        <ComboBoxItem Content="Info"/>
                        <ComboBoxItem Content="Warning"/>
                        <ComboBoxItem Content="Error"/>
                    </ComboBox>
                    <TextBlock Text="Category:" Foreground="#CCC" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox x:Name="LogCategoryFilter" Width="110" Margin="2,0"
                              SelectionChanged="LogFilter_Changed">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="HtmlRenderer"/>
                        <ComboBoxItem Content="JavaScript"/>
                    </ComboBox>
                    <TextBox x:Name="LogSearchBox" Width="180" Margin="8,0,2,0"
                             Foreground="#CCC" BorderBrush="#555"
                             VerticalContentAlignment="Center" Padding="4,2"
                             TextChanged="LogFilter_Changed"/>
                    <TextBlock Text="🔍" Foreground="#999" VerticalAlignment="Center" Margin="2,0"/>
                    <Button Content="Clear" Margin="8,0,2,0" Padding="8,2" Click="ClearLog_Click"
                            Foreground="#CCC" BorderBrush="#555"/>
                </StackPanel>
            </Border>

            <!-- Log entries -->
            <ListBox x:Name="LogList" Grid.Row="1" Foreground="#CCC"
                     BorderThickness="0" FontFamily="Consolas" FontSize="12"
                     Background="#1E1E1E"/>
        </Grid>

        <!-- DOM Inspector Tab -->
        <Grid x:Name="DomPanel" Grid.Row="1" IsVisible="False" Background="#1E1E1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Box tree -->
            <TreeView x:Name="DomTree" Grid.Column="0" Foreground="#CCC"
                      BorderThickness="0" FontFamily="Consolas" FontSize="12"
                      Background="#1E1E1E"
                      SelectionChanged="DomTree_SelectionChanged"/>

            <GridSplitter Grid.Column="1" Width="4" Background="#3E3E3E"/>

            <!-- Right pane: Computed Styles + Box Model -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>

                <!-- Computed Styles -->
                <Border Grid.Row="0" BorderBrush="#3E3E3E" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Computed Styles" Foreground="#4EC9B0" FontWeight="Bold"
                                   Margin="8,4" FontSize="12"/>
                        <ListBox x:Name="StylesList" Grid.Row="1" Foreground="#CCC"
                                 BorderThickness="0" FontFamily="Consolas" FontSize="11"
                                 Background="#1E1E1E"/>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="4" Background="#3E3E3E"/>

                <!-- Box Model Visualiser -->
                <Border Grid.Row="2" BorderBrush="#3E3E3E" BorderThickness="1,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Box Model" Foreground="#4EC9B0" FontWeight="Bold"
                                   Margin="8,4" FontSize="12"/>
                        <Canvas x:Name="BoxModelCanvas" Grid.Row="1" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- JS Console Tab -->
        <Grid x:Name="JsPanel" Grid.Row="1" IsVisible="False" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Output -->
            <ListBox x:Name="JsOutput" Grid.Row="0" Foreground="#CCC"
                     BorderThickness="0" FontFamily="Consolas" FontSize="12"
                     Background="#1E1E1E"/>

            <!-- Input -->
            <Border Grid.Row="1" BorderBrush="#3E3E3E" BorderThickness="0,1,0,0"
                    Background="#2D2D2D">
                <DockPanel Margin="4">
                    <TextBlock Text="&gt;" Foreground="#569CD6" VerticalAlignment="Center"
                               Margin="4,0" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                    <TextBox x:Name="JsInput" Foreground="#CCC"
                             BorderBrush="#555" FontFamily="Consolas" FontSize="12"
                             VerticalContentAlignment="Center" Padding="4,2"
                             KeyDown="JsInput_KeyDown"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
