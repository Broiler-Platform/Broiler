<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Broiler.HtmlBridge</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Rendering-specific HtmlBridge layout, paint, image, SVG, and canvas helpers.</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Broiler" />
    <InternalsVisibleTo Include="Broiler.Browser.Core" />
    <InternalsVisibleTo Include="Broiler.Cli" />
    <InternalsVisibleTo Include="Broiler.Cli.Tests" />
    <InternalsVisibleTo Include="Broiler.DevConsole" />
    <InternalsVisibleTo Include="Broiler.DevConsole.Tests" />
    <InternalsVisibleTo Include="Broiler.Wpt" />
    <InternalsVisibleTo Include="Broiler.Wpt.Tests" />
  </ItemGroup>

  <!-- Phase 1 (project-graph repair): the geometry provider moved to
       Broiler.HTML.Headless behind ILayoutView, so Rendering no longer references
       Broiler.HTML.Image or Broiler.Dom. The remaining CanvasCommandRecorder and
       HtmlPostProcessor helpers depend on nothing outside the BCL. -->

</Project>
