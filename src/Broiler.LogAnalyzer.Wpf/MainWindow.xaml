<Window x:Class="Broiler.LogAnalyzer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Broiler.LogAnalyzer.Wpf"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Broiler Log Analyzer" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        MinHeight="500" MinWidth="800"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Window.Resources>
        <local:StatusCodeToBrushConverter x:Key="StatusCodeToBrush"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File Selection -->
        <GroupBox Grid.Row="0" Header="Log File Selection (or drag-and-drop files here)" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox" Grid.Column="0"
                         VerticalContentAlignment="Center" Padding="4,2"
                         IsReadOnly="True"
                         Text="Select a log file or directory (or drag-and-drop)..."/>
                <Button x:Name="BrowseFileButton" Grid.Column="1"
                        Content="Browse File…" Margin="8,0,0,0" Padding="12,4"
                        Click="BrowseFileButton_Click"/>
                <Button x:Name="BrowseFolderButton" Grid.Column="2"
                        Content="Browse Folder…" Margin="8,0,0,0" Padding="12,4"
                        Click="BrowseFolderButton_Click"/>
            </Grid>
        </GroupBox>

        <!-- Options and Analyze Button -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Top N results:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TopNTextBox" Grid.Column="1" Width="60" Text="10"
                     VerticalContentAlignment="Center" Padding="4,2"/>
            <Button x:Name="ThemeToggleButton" Grid.Column="3"
                    Content="🌙 Dark" Padding="12,4" Margin="0,0,8,0"
                    Click="ThemeToggleButton_Click"/>
            <Button x:Name="AnalyzeButton" Grid.Column="4"
                    Content="Analyze" Padding="20,6" FontWeight="SemiBold"
                    Click="AnalyzeButton_Click" IsEnabled="False"/>
        </Grid>

        <!-- Quick-Filter Toolbar -->
        <GroupBox Grid.Row="2" Header="Quick Filters" Padding="6" Margin="0,0,0,8"
                  x:Name="FilterGroupBox" IsEnabled="False">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="FilterStatusCombo" Width="100" Margin="0,0,12,0"
                          SelectionChanged="FilterSelection_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="2xx"/>
                    <ComboBoxItem Content="3xx"/>
                    <ComboBoxItem Content="4xx"/>
                    <ComboBoxItem Content="5xx"/>
                </ComboBox>

                <TextBlock Text="Method:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox x:Name="FilterMethodCombo" Width="90" Margin="0,0,12,0"
                          SelectionChanged="FilterSelection_Changed">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                </ComboBox>

                <TextBlock Text="IP:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="FilterIpTextBox" Width="120" Margin="0,0,12,0"
                         VerticalContentAlignment="Center" Padding="4,2"
                         TextChanged="FilterText_Changed"/>

                <TextBlock Text="Endpoint:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="FilterEndpointTextBox" Width="150" Margin="0,0,12,0"
                         VerticalContentAlignment="Center" Padding="4,2"
                         TextChanged="FilterText_Changed"/>

                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="FilterSearchTextBox" Width="180" Margin="0,0,12,0"
                         VerticalContentAlignment="Center" Padding="4,2"
                         TextChanged="FilterText_Changed"/>

                <Button Content="Clear Filters" Padding="8,4" Click="ClearFilters_Click"/>
            </WrapPanel>
        </GroupBox>

        <!-- Results — tabbed: Log Entries (DataGrid) + Summary (TextBox) + Charts + Per-Host Details -->
        <TabControl Grid.Row="3" Margin="0,0,0,0" x:Name="ResultsTabControl"
                    SelectionChanged="ResultsTabControl_SelectionChanged">
            <TabItem Header="Log Entries">
                <DataGrid x:Name="LogEntriesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F9F9F9"
                          FontFamily="Consolas" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background"
                                    Value="{Binding StatusCode, Converter={StaticResource StatusCodeToBrush}}"/>
                            <Setter Property="ToolTip"
                                    Value="{Binding FormattedEntry}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Remote Host" Binding="{Binding RemoteHost}" Width="130"/>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss zzz}'}" Width="200"/>
                        <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="70"/>
                        <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="60"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding ResponseSize}" Width="80"/>
                        <DataGridTextColumn Header="Referer" Binding="{Binding Referer}" Width="220"/>
                        <DataGridTextColumn Header="User Agent" Binding="{Binding UserAgent}" Width="200"/>
                        <DataGridTextColumn Header="Log Entry" Binding="{Binding FormattedEntry}" Width="420"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Summary">
                <TextBox x:Name="ResultsTextBox"
                         IsReadOnly="True" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         TextWrapping="NoWrap"/>
            </TabItem>
            <TabItem Header="Charts" x:Name="ChartsTab">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4,8,0">
                        <Button x:Name="ExportChartPngButton" Content="Export Charts as PNG…"
                                Padding="10,4" Margin="0,0,8,0"
                                Click="ExportChartPng_Click" IsEnabled="False"/>
                        <Button x:Name="ExportChartSvgButton" Content="Export Charts as SVG…"
                                Padding="10,4"
                                Click="ExportChartSvg_Click" IsEnabled="False"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChartsPanel" Margin="8">
                            <TextBlock Text="Run analysis to view charts." FontSize="14"
                                       Foreground="Gray" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Margin="0,20,0,0"
                                       x:Name="ChartsPlaceholder"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Heatmap" x:Name="HeatmapTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="HeatmapPanel" Margin="8">
                        <TextBlock Text="Run analysis to view heatmap." FontSize="14"
                                   Foreground="Gray" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,20,0,0"
                                   x:Name="HeatmapPlaceholder"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Per-Host Details" x:Name="PerHostTab">
                <DataGrid x:Name="PerHostGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F9F9F9"
                          FontFamily="Consolas" FontSize="12"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="180"/>
                        <DataGridTextColumn Header="Requests" Binding="{Binding Requests, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="Bytes Transferred" Binding="{Binding BytesTransferred, StringFormat=N0}" Width="140"/>
                        <DataGridTextColumn Header="Errors" Binding="{Binding ErrorCount, StringFormat=N0}" Width="80"/>
                        <DataGridTextColumn Header="Error Rate" Binding="{Binding ErrorRate, StringFormat=P1}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
