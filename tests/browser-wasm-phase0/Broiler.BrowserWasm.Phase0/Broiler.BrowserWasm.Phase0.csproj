<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType Condition="'$(RuntimeIdentifier)' != 'browser-wasm'">Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <IsPackable>false</IsPackable>
    <RootNamespace>Broiler.BrowserWasm.Phase0</RootNamespace>
    <AssemblyName>Broiler.BrowserWasm.Phase0</AssemblyName>
  </PropertyGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'browser-wasm'">
    <!-- The browser-RID build validates only the exact dependency closure. The
         desktop-only artifact generator is executed separately in CI. -->
    <Compile Remove="Program.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(RuntimeIdentifier)' != 'browser-wasm'">
    <Compile Remove="BrowserClosureMarker.cs" />
